---
import Layout from '../layouts/Layout.astro';

const experiences = [
  {
    period: '2023 - 至今',
    title: '高级前端工程师',
    company: '某科技公司',
    description: '负责公司核心产品的前端架构设计与开发，带领团队完成多个大型项目。'
  },
  {
    period: '2020 - 2023',
    title: '全栈开发工程师',
    company: '某互联网公司',
    description: '参与前后端开发，使用 Java、Redis、Go 等技术栈构建 Web 应用。'
  },
  {
    period: '2018 - 2020',
    title: '初级开发工程师',
    company: '某创业公司',
    description: '参与产品原型开发，学习并掌握现代 Web 开发技术。'
  }
];

const skills = [
  { name: '前端开发', items: ['Vue.js', 'JavaScript'] },
  { name: '后端开发', items: ['Java', 'Redis', 'Go', 'PostgreSQL', 'MongoDB'] },
  { name: 'DevOps', items: ['Docker', 'Kubernetes', 'CI/CD', 'Linux'] },
  { name: '工具', items: ['Git', 'GitHub', 'VS Code', 'Postman'] }
];

const techParticles = Array.from({ length: 32 }, (_, index) => ({
  left: (index * 37) % 100,
  top: (index * 29) % 88,
  delay: -(index % 10) * 0.42,
  duration: 7 + (index % 6),
  size: 10 + (index % 5) * 5,
  drift: index % 2 === 0 ? 42 + index : -38 - index,
  type: ['data', 'network', 'light', 'signal'][index % 4],
}));
---

<Layout title="关于我 - liuzhne" description="了解更多关于我的信息">
  <div class="about-page">
    <section class="about-hero relative overflow-hidden px-4 py-24 text-center md:py-32">
      <div class="tech-field pointer-events-none absolute inset-0" aria-hidden="true">
        <div class="network-line network-line-a absolute"></div>
        <div class="network-line network-line-b absolute"></div>
        <div class="network-line network-line-c absolute"></div>
        {techParticles.map((particle) => (
          <span
            class={`tech-particle tech-${particle.type} absolute`}
            style={`--x:${particle.left}%; --y:${particle.top}%; --delay:${particle.delay}s; --duration:${particle.duration}s; --size:${particle.size}px; --drift:${particle.drift}px; --from-x:${50 - particle.left}vw; --from-y:${38 - particle.top}vh; --burst-delay:${(particle.left + particle.top) % 9 * 0.035}s;`}
          />
        ))}
      </div>
      <div class="relative mx-auto max-w-4xl">
        <p class="mb-4 text-lg font-semibold text-blue-600 dark:text-blue-300 md:text-xl">
          关于我
        </p>
        <h1 class="mx-auto max-w-3xl text-6xl font-bold tracking-tight text-gray-950 dark:text-white md:text-8xl">
          liuzhne
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-xl leading-8 text-gray-600 dark:text-blue-100/80 md:text-2xl">
          写代码，做系统，也记录一路上的技术判断。
        </p>
      </div>
    </section>

    <section class="px-4 py-16">
      <div class="mx-auto grid max-w-4xl gap-8 md:grid-cols-[0.85fr_1.15fr] md:items-center">
        <div>
          <p class="text-sm font-semibold text-blue-600 dark:text-blue-400">Profile</p>
          <h2 class="mt-3 text-4xl font-bold tracking-tight text-gray-950 dark:text-white md:text-5xl">
            全栈开发者，偏爱清晰、稳定的工程实践。
          </h2>
        </div>
        <div class="space-y-5 text-lg leading-8 text-gray-600 dark:text-gray-300">
          <p>
            你好！我是 <strong class="text-gray-950 dark:text-white">liuzhne</strong>，一名热爱编程的全栈开发者。我在 Web 开发领域有多年的经验，专注于构建高性能、用户友好的应用程序。
          </p>
          <p>
            我的技术栈涵盖前端、后端与 DevOps，包括 Vue.js、JavaScript、Java、Redis、Go、PostgreSQL、MongoDB、Docker、Kubernetes、CI/CD 和 Linux 等。我对新技术保持好奇心，也重视把技术沉淀为稳定、可维护的工程实践。
          </p>
          <p>
            创建这个博客的目的是记录我的学习历程，分享技术心得，同时也希望能够帮助到其他开发者。
          </p>
        </div>
      </div>
    </section>

    <section class="bg-gray-50 px-4 py-20 dark:bg-gray-800/40">
      <div class="mx-auto max-w-4xl">
        <div class="mb-10 text-center">
          <p class="text-sm font-semibold text-blue-600 dark:text-blue-400">Stack</p>
          <h2 class="mt-3 text-4xl font-bold tracking-tight text-gray-950 dark:text-white md:text-5xl">技术栈</h2>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          {skills.map((category) => (
            <section class="rounded-[28px] bg-white p-8 shadow-sm ring-1 ring-gray-200 dark:bg-gray-900 dark:ring-gray-700">
              <h3 class="text-2xl font-bold text-gray-950 dark:text-white">{category.name}</h3>
              <div class="mt-6 flex flex-wrap gap-2">
                {category.items.map((skill) => (
                  <span class="rounded-full bg-blue-50 px-4 py-2 text-sm font-medium text-blue-700 dark:bg-blue-950 dark:text-blue-200">
                    {skill}
                  </span>
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>

    <section class="px-4 py-20">
      <div class="mx-auto max-w-4xl">
        <div class="mb-10 text-center">
          <p class="text-sm font-semibold text-blue-600 dark:text-blue-400">Experience</p>
          <h2 class="mt-3 text-4xl font-bold tracking-tight text-gray-950 dark:text-white md:text-5xl">工作经历</h2>
        </div>
        <div class="divide-y divide-gray-200 rounded-[28px] bg-white px-6 shadow-sm ring-1 ring-gray-200 dark:divide-gray-700 dark:bg-gray-900 dark:ring-gray-700 md:px-10">
          {experiences.map((exp) => (
            <section class="grid gap-4 py-8 md:grid-cols-[160px_1fr]">
              <time class="text-sm font-medium text-gray-500 dark:text-gray-400">{exp.period}</time>
              <div>
                <h3 class="text-2xl font-bold text-gray-950 dark:text-white">{exp.title}</h3>
                <p class="mt-1 text-blue-600 dark:text-blue-400">{exp.company}</p>
                <p class="mt-4 text-lg leading-8 text-gray-600 dark:text-gray-300">{exp.description}</p>
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>

    <section class="px-4 pb-24 text-center">
      <div class="mx-auto max-w-3xl rounded-[32px] bg-gray-950 px-8 py-14 text-white dark:bg-white dark:text-gray-950">
        <h2 class="text-4xl font-bold tracking-tight md:text-5xl">一起交流技术想法。</h2>
        <p class="mx-auto mt-5 max-w-xl text-lg leading-8 text-gray-300 dark:text-gray-600">
          如果你有任何问题、建议，或者只是想聊聊技术与工程实践，欢迎联系我。
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a
            href="https://github.com/liuzhne"
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full bg-white px-5 py-3 text-sm font-semibold text-gray-950 transition hover:bg-gray-200 dark:bg-gray-950 dark:text-white dark:hover:bg-gray-800"
          >
            GitHub
          </a>
          <a
            href="mailto:1044307322@qq.com"
            class="rounded-full bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-blue-700"
          >
            Email
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .about-hero {
    min-height: 560px;
    display: grid;
    place-items: center;
    background:
      radial-gradient(circle at 50% 18%, rgba(191, 219, 254, 0.62), transparent 30rem),
      linear-gradient(180deg, #eff6ff 0%, #f8fbff 56%, #ffffff 100%);
  }

  :global(.dark) .about-hero {
    background:
      radial-gradient(circle at 50% 28%, rgba(37, 99, 235, 0.28), transparent 28rem),
      radial-gradient(circle at 16% 12%, rgba(96, 165, 250, 0.12), transparent 22rem),
      linear-gradient(180deg, #020817 0%, #061226 52%, #08111f 100%);
  }

  .tech-field {
    transform-origin: 50% 38%;
    animation: field-burst 1100ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .network-line {
    height: 1px;
    width: 28vw;
    background: linear-gradient(90deg, transparent, rgba(37, 99, 235, 0.42), transparent);
    transform-origin: center;
    animation: signal-sweep 7s ease-in-out infinite;
  }

  .network-line-a {
    top: 23%;
    left: 12%;
    transform: rotate(14deg);
  }

  .network-line-b {
    top: 42%;
    right: 10%;
    transform: rotate(-18deg);
    animation-delay: -2s;
  }

  .network-line-c {
    bottom: 25%;
    left: 35%;
    transform: rotate(6deg);
    animation-delay: -4s;
  }

  .tech-particle {
    display: block;
    top: var(--y);
    left: var(--x);
    width: var(--size);
    height: var(--size);
    color: rgba(37, 99, 235, 0.48);
    opacity: 0.9;
    transform-origin: center;
    animation:
      particle-burst 980ms cubic-bezier(0.16, 1, 0.3, 1) both,
      tech-float var(--duration) ease-in-out infinite;
    animation-delay: var(--burst-delay), calc(980ms + var(--delay));
  }

  .tech-data::before,
  .tech-network::before,
  .tech-light::before,
  .tech-signal::before,
  .tech-data::after,
  .tech-network::after,
  .tech-light::after,
  .tech-signal::after {
    content: "";
    position: absolute;
  }

  .tech-data::before {
    inset: 20%;
    border-radius: 999px;
    background: rgba(37, 99, 235, 0.48);
    box-shadow:
      calc(var(--size) * 0.7) calc(var(--size) * -0.35) 0 rgba(100, 116, 139, 0.38),
      calc(var(--size) * -0.55) calc(var(--size) * 0.45) 0 rgba(59, 130, 246, 0.3);
  }

  .tech-network::before {
    left: 8%;
    top: 48%;
    width: 84%;
    height: 1px;
    background: currentColor;
    transform: rotate(28deg);
  }

  .tech-network::after {
    inset: 18%;
    border-radius: 999px;
    border: 1px solid currentColor;
    box-shadow: calc(var(--size) * 0.55) calc(var(--size) * -0.2) 0 -1px currentColor;
  }

  .tech-light::before {
    inset: 8%;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.34), rgba(147, 197, 253, 0.08) 58%, transparent 70%);
    filter: blur(0.5px);
  }

  .tech-signal::before {
    inset: 20%;
    border-radius: 999px;
    border: 1px solid rgba(37, 99, 235, 0.45);
  }

  .tech-signal::after {
    inset: 0;
    border-radius: 999px;
    border: 1px solid rgba(37, 99, 235, 0.24);
  }

  @keyframes tech-float {
    0% {
      transform: translate3d(0, 0, 0) rotate(0deg) scale(0.96);
    }

    50% {
      transform: translate3d(calc(var(--drift) * 0.35), -22px, 0) rotate(8deg) scale(1.06);
    }

    100% {
      transform: translate3d(0, 0, 0) rotate(0deg) scale(0.96);
    }
  }

  @keyframes particle-burst {
    0% {
      opacity: 0;
      transform: translate3d(var(--from-x), var(--from-y), 0) scale(0.28) rotate(-18deg);
      filter: blur(8px);
    }

    58% {
      opacity: 1;
      filter: blur(0);
    }

    100% {
      opacity: 0.9;
      transform: translate3d(0, 0, 0) scale(1) rotate(0deg);
      filter: blur(0);
    }
  }

  @keyframes field-burst {
    0% {
      opacity: 0;
      transform: scale(0.18);
      filter: blur(18px);
    }

    62% {
      opacity: 1;
      filter: blur(0);
    }

    100% {
      opacity: 1;
      transform: scale(1);
      filter: blur(0);
    }
  }

  @keyframes signal-sweep {
    0%,
    100% {
      opacity: 0.08;
    }

    50% {
      opacity: 0.34;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tech-field,
    .tech-particle,
    .network-line {
      animation: none;
      opacity: 0.18;
    }
  }
</style>
