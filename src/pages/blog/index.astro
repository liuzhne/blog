---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => {
  return data.draft !== true;
});

const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="博客" description="技术博客与知识分享">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <header class="mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
        我的博客
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
        分享编程经验、技术心得与学习笔记
      </p>
    </header>

    <p
      id="blog-search-status"
      class="hidden mb-6 text-sm text-gray-500 dark:text-gray-400"
      aria-live="polite"
    >
    </p>

    <div id="blog-posts" class="grid gap-8">
      {sortedPosts.length === 0 ? (
        <div class="text-center py-16 text-gray-500 dark:text-gray-400">
          <p class="text-lg">还没有发布文章，敬请期待...</p>
        </div>
      ) : (
        sortedPosts.map((post) => {
          const formattedDate = post.data.pubDate.toLocaleDateString('zh-CN', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return (
            <article
              data-blog-post
              data-search-text={`${post.data.title} ${post.data.description} ${post.data.tags.join(' ')}`.toLowerCase()}
              class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow border border-gray-200 dark:border-gray-700"
            >
              <a href={`/blog/posts/${post.id}/`} class="block">
                <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500 dark:text-gray-400 mb-3">
                  <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
                  {post.data.tags.length > 0 && (
                    <>
                      <span>·</span>
                      <div class="flex flex-wrap gap-2">
                        {post.data.tags.map((tag) => (
                          <span class="text-blue-600 dark:text-blue-400">#{tag}</span>
                        ))}
                      </div>
                    </>
                  )}
                </div>
                <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-gray-600 dark:text-gray-300">
                  {post.data.description}
                </p>
              </a>
            </article>
          );
        })
      )}
    </div>

    <div
      id="blog-empty-search"
      class="hidden text-center py-16 text-gray-500 dark:text-gray-400"
    >
      <p class="text-lg">没有找到匹配的文章</p>
    </div>
  </div>
</Layout>

<script>
  const searchInputs = document.querySelectorAll<HTMLInputElement>('[data-blog-search-input]');
  const posts = Array.from(document.querySelectorAll<HTMLElement>('[data-blog-post]'));
  const searchStatus = document.getElementById('blog-search-status');
  const emptySearch = document.getElementById('blog-empty-search');

  function normalizeQuery(value: string) {
    return value.trim().toLowerCase();
  }

  function applyBlogSearch(value: string, updateUrl = false) {
    const query = normalizeQuery(value);
    let visibleCount = 0;

    posts.forEach((post) => {
      const text = post.dataset.searchText ?? '';
      const isVisible = query === '' || text.includes(query);
      post.classList.toggle('hidden', !isVisible);
      if (isVisible) visibleCount += 1;
    });

    if (searchStatus) {
      searchStatus.classList.toggle('hidden', query === '');
      searchStatus.textContent = query === '' ? '' : `搜索 “${value.trim()}”，找到 ${visibleCount} 篇文章`;
    }

    emptySearch?.classList.toggle('hidden', query === '' || visibleCount > 0);

    if (updateUrl) {
      const url = new URL(window.location.href);
      if (query === '') {
        url.searchParams.delete('q');
      } else {
        url.searchParams.set('q', value.trim());
      }
      window.history.replaceState({}, '', url);
    }
  }

  const initialQuery = new URLSearchParams(window.location.search).get('q') ?? '';
  searchInputs.forEach((input) => {
    input.value = initialQuery;
    input.addEventListener('input', () => {
      searchInputs.forEach((otherInput) => {
        if (otherInput !== input) otherInput.value = input.value;
      });
      applyBlogSearch(input.value, true);
    });
  });
  applyBlogSearch(initialQuery);
</script>
